{
	"compilerOptions": {
		"outDir": "./dist/",
		"noImplicitAny": true,
		"module": "ESNext",
		"jsx": "react",
		"allowJs": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"paths": {
			"@/*": ["./src/*"],
			"@img/*": ["./src/img/*"],
			"@svg/*": ["./src/svg/*"],
			"@sections/*": ["./src/modules/sections/*"],
			"@scss/*": ["./src/scss/*"],
			"@modules/*": ["./src/js/modules/*"],
			"@components/*": ["./src/js/components/*"],
			"@helpers/*": ["./src/js/helpers/*"],
			"@utils/*": ["./src/js/utils/*"],
			"@module/*": ["./node_modules/*"]
		}
	},
	"ts-node": {
		"compilerOptions": {
			"module": "CommonJS"
		}
	}
}
